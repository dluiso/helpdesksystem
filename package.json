{
  "name": "avidity-it-management-tool",
  "private": true,
  "version": "0.1.0",
  "description": "Modular IT management platform for MSP and internal IT operations.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @avidity/api run start:dev",
    "dev:web": "npm --workspace @avidity/web run dev",
    "build": "npm-run-all build:shared build:api build:web",
    "build:shared": "npm --workspace @avidity/shared run build && npm --workspace @avidity/config run build && npm --workspace @avidity/ui run build",
    "build:api": "npm --workspace @avidity/api run build",
    "build:web": "npm --workspace @avidity/web run build",
    "lint": "npm-run-all lint:api lint:web",
    "lint:api": "npm --workspace @avidity/api run lint",
    "lint:web": "npm --workspace @avidity/web run lint",
    "test": "npm --workspace @avidity/api run test",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "dotenv": "^16.4.5",
    "npm-run-all": "^4.1.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "postcss": "8.5.22",
    "esbuild": "0.28.1",
    "sharp": "0.35.3",
    "brace-expansion@^1.1.7": "1.1.16",
    "brace-expansion@^2.0.1": "2.1.2",
    "next": {
      "postcss": "8.5.22"
    }
  },
  "dependencies": {
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  }
}
