APP_NAME="Avidity IT Management Tool"
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
CORS_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avidity_it_management
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/avidity_it_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=avidity_it_management
REDIS_URL=redis://localhost:6379
DOCKER_REDIS_URL=redis://redis:6379

SESSION_SECRET=change-me-to-a-long-random-value
SESSION_COOKIE_NAME=avidity_session
SESSION_TTL_HOURS=12
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SUPPORT_MAILBOX=support@aviditytechnologies.com
MICROSOFT_INGESTION_MAILBOX=
MAIL_PROVIDER=auto
MOCK_INBOUND_EMAIL_ENABLED=true
MOCK_INBOUND_SENDER_EMAIL=requester@example.org
MOCK_INBOUND_SENDER_NAME="Mock Requester"

AI_PROVIDER=mock
AI_MODEL=mock
AI_API_KEY=
AI_BASE_URL=

FILE_STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage/local
MAX_UPLOAD_SIZE_MB=25

DEFAULT_COMPANY_NAME="Avidity Technologies"
DEFAULT_SUPPORT_EMAIL=support@aviditytechnologies.com
DEFAULT_TIMEZONE=America/Chicago
DEFAULT_LANGUAGE=en

ADMIN_EMAIL=admin@aviditytechnologies.com
ADMIN_PASSWORD=ChangeMeNow!123
