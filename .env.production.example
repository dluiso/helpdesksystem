APP_NAME="Avidity IT Management Tool"
APP_ENV=production
APP_URL=https://support.aviditytechnologies.com
API_URL=https://support.aviditytechnologies.com/api
NEXT_PUBLIC_API_URL=https://support.aviditytechnologies.com/api
CORS_ORIGINS=https://support.aviditytechnologies.com
PORT=4000

POSTGRES_DB=avidity_it_management
POSTGRES_USER=AvidityIT
POSTGRES_PASSWORD=replace-with-a-strong-database-password

SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=avidity_session
SESSION_TTL_HOURS=12
COOKIE_DOMAIN=support.aviditytechnologies.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SUPPORT_MAILBOX=support@aviditytechnologies.com
MICROSOFT_INGESTION_MAILBOX=
MAIL_PROVIDER=auto
MOCK_INBOUND_EMAIL_ENABLED=false

AI_PROVIDER=mock
AI_MODEL=mock
AI_API_KEY=
AI_BASE_URL=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

FILE_STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/opt/avidity/app/storage/local
MAX_UPLOAD_SIZE_MB=25

DEFAULT_COMPANY_NAME="Avidity Technologies"
DEFAULT_SUPPORT_EMAIL=support@aviditytechnologies.com
DEFAULT_TIMEZONE=America/Chicago
DEFAULT_LANGUAGE=en

ADMIN_EMAIL=admin@aviditytechnologies.com
ADMIN_PASSWORD=replace-before-seeding
