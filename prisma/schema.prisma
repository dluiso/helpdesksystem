  updatedAt                  DateTime       @updatedAt
  organization               Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                     Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contact                    Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedUser               User?          @relation("AssignedTickets", fields: [assignedUserId], references: [id], onDelete: SetNull)
  firstReadBy                User?          @relation("TicketFirstReadBy", fields: [firstReadByUserId], references: [id], onDelete: SetNull)
  assignedGroup              Group?         @relation("AssignedGroupTickets", fields: [assignedGroupId], references: [id], onDelete: SetNull)
  assignedTeam               TicketTeam?    @relation("AssignedTeamTickets", fields: [assignedTeamId], references: [id], onDelete: SetNull)
  appliedRoutingRule         TicketRoutingRule? @relation("AppliedRoutingRuleTickets", fields: [appliedRoutingRuleId], references: [id], onDelete: SetNull)
  mailbox                    Mailbox?       @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  mergedIntoTicket           Ticket?        @relation("TicketMergeHierarchy", fields: [mergedIntoTicketId], references: [id], onDelete: SetNull)
  mergedTickets              Ticket[]       @relation("TicketMergeHierarchy")
  mergedBy                   User?          @relation("TicketMergedBy", fields: [mergedByUserId], references: [id], onDelete: SetNull)
  mergeOperationsAsPrimary   TicketMerge[]  @relation("TicketMergePrimary")
  messages                   TicketMessage[]
  messagesMergedFromThisTicket TicketMessage[] @relation("MergedFromTicketMessages")
  attachments                TicketAttachment[]
  assignees                  TicketAssignee[]
  externalSpecialists        TicketExternalSpecialist[]
