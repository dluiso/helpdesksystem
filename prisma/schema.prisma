generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum MailboxProvider {
  MICROSOFT365
  MOCK
}

enum MailboxConnectionMode {
  GRAPH_DIRECT
  GRAPH_FORWARDED_MAILBOX
  MOCK
}

enum MailboxOutboundMode {
  GRAPH_SEND_AS
  GRAPH_SEND_ON_BEHALF
  SMTP_RELAY
  NONE
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  WAITING_ON_TECHNICIAN
  WAITING_ON_THIRD_PARTY
  RESOLVED
  CLOSED
  REOPENED
  CANCELLED
  MERGED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum TicketSource {
  MANUAL
  EMAIL
  PORTAL
  API
  SYSTEM
}

enum SpamBlockType {
  EMAIL
  DOMAIN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum MessageVisibility {
  PUBLIC
  INTERNAL
}

enum AttachmentSource {
  INBOUND_EMAIL
  OUTBOUND_REPLY
  INTERNAL_UPLOAD
  PASTED_IMAGE
  SYSTEM
}

enum AttachmentScanStatus {
  PENDING
  CLEAN
  SUSPICIOUS
  BLOCKED
}

enum AttachmentScanResult {
  NOT_SCANNED
  PASSED
  FAILED
  SKIPPED
}

enum FileStorageProvider {
  LOCAL
  S3
  MINIO
  AZURE_BLOB
}

enum AutoReplyScope {
  GLOBAL
  CLIENT
  MAILBOX
  AFTER_HOURS
  PRIORITY
}

enum AutoReplyTemplateType {
  TICKET
  EVENT_SERVICE
}

enum AutoReplyTrigger {
  TICKET_CREATED
  EVENT_REQUEST_CREATED
  EVENT_STATUS_CHANGED
}

enum KnowledgeVisibility {
  INTERNAL
  PUBLIC
}

enum KnowledgeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DeviceType {
  DESKTOP
  LAPTOP
  SERVER
  PHONE
  TABLET
  OTHER
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  RETIRED
}

enum DeviceViewScope {
  PRIVATE
  ADMINISTRATORS
}

enum RemoteAccessProvider {
  RUSTDESK
  MESH_CENTRAL
  TACTICAL_RMM
  MANUAL
  OTHER
}

enum AiProvider {
  MOCK
  OPENAI_COMPATIBLE
  ANTHROPIC
  GEMINI
  AZURE_OPENAI
  OLLAMA
  CUSTOM_HTTP
}

enum NotificationStatus {
  UNREAD
  READ
}

enum RoutingConditionMatch {
  ANY
  ALL
}

enum EventServiceRequestStatus {
  NEW
  UNDER_REVIEW
  SCHEDULED
  ASSIGNED
  IN_PROGRESS
  WAITING_ON_CLIENT
  WAITING_ON_INTERNAL_TEAM
  COMPLETED
  CANCELLED
  CONVERTED_TO_TICKET
}

enum EventServiceTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectHealth {
  ON_TRACK
  AT_RISK
  OFF_TRACK
}

enum ProjectMilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

enum EventServiceFieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  DATE
  TIME
  SELECT
  MULTI_SELECT
  CHECKBOX
  RADIO
  NUMBER
}

model Organization {
  id             String             @id @default(uuid()) @db.Uuid
  name           String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  settings       SystemSetting?
  users          User[]
  groups         Group[]
  roles          Role[]
  clients        Client[]
  mailboxes      Mailbox[]
  tickets        Ticket[]
  ticketTeams    TicketTeam[]
  ticketRoutingRules TicketRoutingRule[]
  ticketMerges   TicketMerge[]
  unmappedEmailDomains UnmappedEmailDomain[]
  knowledgeCategories KnowledgeCategory[]
  knowledgeArticles   KnowledgeArticle[]
  autoReplyTemplates  AutoReplyTemplate[]
  aiProviders         AiProviderConfig[]
  aiModels            AiModelConfig[]
  aiActionSettings    AiActionSetting[]
  spamBlockEntries    SpamBlockEntry[]
  blockedInboundEmails BlockedInboundEmail[]
  reportDefinitions   ReportDefinition[]
  reportSchedules     ReportSchedule[]
  reportExports       ReportExport[]
  passwordResetTokens  PasswordResetToken[]
  mfaLoginChallenges   MfaLoginChallenge[]
  mfaSetupChallenges   MfaSetupChallenge[]
  mfaTrustedDevices    MfaTrustedDevice[]
  microsoftSsoLoginChallenges MicrosoftSsoLoginChallenge[]
  eventServiceRequests EventServiceRequest[]
  eventServiceServices EventServiceService[]
  eventServiceForms    EventServiceForm[]
  eventServiceSequences EventServiceSequence[]
  externalSpecialists  ExternalSpecialist[]
  supportPortalForms   SupportPortalForm[]
  deviceViews          UserDeviceView[]
  auditLogs            AuditLog[]
  projects             Project[]

  @@map("organizations")
}

model SystemSetting {
  id                         String   @id @default(uuid()) @db.Uuid
  organizationId             String   @unique @db.Uuid
  applicationName            String
  companyName                String
  logoUrl                    String?
  loginLogoUrl               String?
  loginFormLogoUrl           String?
  mobileLogoUrl              String?
  mobileLoginLogoUrl         String?
  appIconUrl                 String?
  loginHeadline              String?
  loginSubtitle              String?
  loginFooterText            String?
  appSubtitle                String?
  showLoginBrandTitle        Boolean  @default(true)
  showSubtitleOnLogin        Boolean  @default(false)
  showSubtitleInApp          Boolean  @default(false)
  subtitlePlacement          String   @default("BELOW")
  mobileSubtitlePlacement    String   @default("BELOW")
  subtitleSize               Int      @default(14)
  subtitleColor              String   @default("#cbd5e1")
  subtitleWeight             String   @default("400")
  subtitleStyle              String   @default("normal")
  subtitleFontFamily         String   @default("system")
  loginLogoWidth             Int      @default(160)
  loginLogoHeight            Int      @default(48)
  loginFormLogoWidth         Int      @default(220)
  loginFormLogoHeight        Int      @default(72)
  brandTextSize              Int      @default(16)
  brandTextColor             String   @default("#ffffff")
  brandLogoBackgroundColor   String   @default("#ffffff")
  brandLogoTransparentBackground Boolean @default(false)
  appBrandTextSize           Int      @default(16)
  appBrandTextColor          String   @default("#ffffff")
  mobileLogoWidth            Int      @default(34)
  mobileLogoHeight           Int      @default(34)
  mobileBrandTextSize        Int      @default(16)
  mobileBrandTextColor       String   @default("#ffffff")
  mobileLoginLogoWidth       Int      @default(140)
  mobileLoginLogoHeight      Int      @default(44)
  mobileLoginBrandTextSize   Int      @default(16)
  mobileLoginBrandTextColor  String   @default("#ffffff")
  brandFontFamily            String   @default("system")
  loginHeadlineSize          Int      @default(48)
  loginHeadlineColor         String   @default("#ffffff")
  loginHeadlineWeight        String   @default("800")
  loginHeadlineStyle         String   @default("normal")
  loginHeadlineFontFamily    String   @default("system")
  loginSubtitleSize          Int      @default(18)
  loginSubtitleColor         String   @default("#ffffff")
  loginSubtitleWeight        String   @default("400")
  loginSubtitleStyle         String   @default("normal")
  loginSubtitleAlign         String   @default("left")
  loginSubtitleFontFamily    String   @default("system")
  loginFooterSize            Int      @default(18)
  loginFooterColor           String   @default("#ffffff")
  loginFooterWeight          String   @default("400")
  loginFooterStyle           String   @default("normal")
  loginFooterFontFamily      String   @default("system")
  primaryColor               String   @default("#155eef")
  secondaryColor             String   @default("#0f172a")
  supportEmail               String
  supportButtonEnabled       Boolean  @default(true)
  supportButtonLabel         String   @default("Support")
  supportButtonUrl           String?
  defaultLandingPage         String   @default("/dashboard")
  defaultTimezone            String   @default("America/Chicago")
  defaultLanguage            String   @default("en")
  dateFormat                 String   @default("MMM dd, yyyy")
  timeFormat                 String   @default("12h")
  emailOperationalHoursEnabled Boolean @default(false)
  emailOperationalTimezone   String   @default("America/Chicago")
  emailOperationalDays       String[] @default(["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"])
  emailOperationalStartTime  String   @default("06:00")
  emailOperationalEndTime    String   @default("17:00")
  emailSkipUsFederalHolidays Boolean  @default(false)
  emailCustomClosedDates     String[] @default([])
  passwordResetEnabled       Boolean  @default(true)
  passwordResetTokenTtlMinutes Int     @default(30)
  mfaUserManagedEnabled      Boolean  @default(true)
  mfaRequiredForAdmins       Boolean  @default(false)
  mfaRequiredForAllUsers     Boolean  @default(false)
  mfaTrustedDeviceDays       Int      @default(30)
  microsoftSsoEnabled        Boolean  @default(false)
  microsoftSsoTenantId       String?
  microsoftSsoClientId       String?
  microsoftSsoClientSecretReference String?
  turnstileEnabled           Boolean  @default(false)
  turnstileSiteKey           String?
  turnstileSecretReference   String?
  turnstileProtectLogin      Boolean  @default(false)
  turnstileProtectPasswordReset Boolean @default(false)
  eventTurnstileEnabled      Boolean  @default(false)
  eventTurnstileSiteKey      String?
  eventTurnstileSecretReference String?
  eventPortalBrowserTitle    String   @default("Schedule Event Support")
  supportPortalEnabled       Boolean  @default(true)
  supportPortalBrowserTitle  String   @default("Support Portal")
  supportPortalTitle         String   @default("Submit a Support Request")
  supportPortalIntroText     String?
  supportPortalSuccessMessage String?
  supportPortalTurnstileEnabled Boolean @default(false)
  supportPortalTurnstileSiteKey String?
  supportPortalTurnstileSecretReference String?
  eventCalendarSyncEnabled   Boolean  @default(false)
  eventCalendarTenantId      String?
  eventCalendarClientId      String?
  eventCalendarClientSecretReference String?
  eventCalendarDefaultTimeZone String @default("America/Chicago")
  eventExternalInviteSubjectTemplate String?
  eventExternalInviteBodyTemplate String?
  knowledgeOneNoteImportEnabled Boolean @default(false)
  knowledgeOneNoteTenantId      String?
  knowledgeOneNoteClientId      String?
  knowledgeOneNoteClientSecretReference String?
  knowledgeOneNoteSourceUserPrincipalName String?
  knowledgeOneNoteDefaultCategoryId String? @db.Uuid
  knowledgeOneNoteRefreshTokenEncrypted String?
  knowledgeOneNoteConnectedUserEmail String?
  knowledgeOneNoteConnectedAt DateTime?
  defaultTicketAutoReplyTemplate String?
  aiAssistantEnabled         Boolean  @default(true)
  remoteAccessProviderEnabled Boolean @default(false)
  remoteAccessProviderName   String   @default("Tactical RMM")
  remoteAccessApiBaseUrl     String?
  remoteAccessApiKeyReference String?
  remoteAccessAgentsPath     String   @default("/agents/")
  remoteAccessDashboardUrl   String?
  remoteAccessDeviceUrlTemplate String?
  remoteAccessControlUrlTemplate String?
  remoteAccessBackgroundUrlTemplate String?
  remoteAccessLastSyncAt     DateTime?
  remoteAccessLastSyncStatus String?
  remoteAccessLastSyncMessage String?
  remoteAccessAutoSyncEnabled Boolean @default(false)
  remoteAccessAutoSyncIntervalMinutes Int?
  remoteAccessNextAutoSyncAt DateTime?
  remoteAccessAutoSyncLockedAt DateTime?
  attachmentStorageProvider  FileStorageProvider @default(LOCAL)
  maximumUploadSizeMb        Int      @default(25)
  allowedAttachmentFileTypes String[] @default([])
  blockedAttachmentFileTypes String[] @default([])
  ticketReopenWindowDays     Int      @default(14)
  recycleBinRetentionDays    Int      @default(7)
  lastRecycleBinCleanupAt    DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("system_settings")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  organizationId      String    @db.Uuid
  email               String    @unique
  passwordHash        String
  firstName           String
  lastName            String
  isActive            Boolean   @default(true)
  forcePasswordChange Boolean   @default(true)
  mfaEnabled          Boolean   @default(false)
  totpSecretEncrypted String?
  recoveryCodesHash   String[]  @default([])
  microsoftTenantId   String?
  microsoftObjectId   String?
  microsoftPrincipalName String?
  microsoftLinkedAt   DateTime?
  lastLoginAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  mfaLoginChallenges  MfaLoginChallenge[]
  mfaSetupChallenges  MfaSetupChallenge[]
  mfaTrustedDevices   MfaTrustedDevice[]
  groups              UserGroup[]
  authoredMessages    TicketMessage[] @relation("UserAuthoredMessages")
  assignedTickets     Ticket[] @relation("AssignedTickets")
  ticketAssignments    TicketAssignee[] @relation("TicketAssigneeUser")
  createdTicketAssignments TicketAssignee[] @relation("TicketAssigneeAssignedBy")
  firstReadTickets     Ticket[] @relation("TicketFirstReadBy")
  mergedTickets        Ticket[] @relation("TicketMergedBy")
  routingRuleAssignments TicketRoutingRule[] @relation("RoutingRuleAssignUser")
  watchedTickets      TicketWatcher[] @relation("TicketWatcherUser")
  createdTicketWatchers TicketWatcher[] @relation("TicketWatcherCreatedBy")
  ticketTeamMemberships TicketTeamMember[]
  notificationPreference UserNotificationPreference?
  notifications       Notification[]
  ticketViews         UserTicketView[]
  dashboardPreference UserDashboardPreference?
  deviceFavorites     UserDeviceFavorite[]
  deviceViews         UserDeviceView[]
  uploadedAttachments TicketAttachment[]
  uploadedEventServiceAttachments EventServiceAttachment[]
  scanOverrideTicketAttachments TicketAttachment[] @relation("TicketAttachmentScanOverride")
  scanOverrideEventServiceAttachments EventServiceAttachment[] @relation("EventServiceAttachmentScanOverride")
  signature           UserSignature?
  auditLogs           AuditLog[]
  aiRequestLogs       AiRequestLog[]
  createdKnowledgeArticles KnowledgeArticle[] @relation("KnowledgeArticleCreatedBy")
  updatedKnowledgeArticles KnowledgeArticle[] @relation("KnowledgeArticleUpdatedBy")
  uploadedKnowledgeArticleAttachments KnowledgeArticleAttachment[] @relation("KnowledgeArticleAttachmentUploadedBy")
  reportExports       ReportExport[]
  reportDefinitions   ReportDefinition[]
  reportSchedules     ReportSchedule[]
  performedTicketMerges TicketMerge[]
  createdSpamBlockEntries SpamBlockEntry[] @relation("SpamBlockEntryCreatedBy")
  assignedEventServiceRequests EventServiceAssignee[]
  assignedEventServiceTasks EventServiceTask[] @relation("EventServiceTaskAssignedUser")
  ticketExternalSpecialists TicketExternalSpecialist[]
  createdEventServiceComments EventServiceComment[]
  eventServiceActivity EventServiceActivity[]
  eventServiceMessages EventServiceMessage[]
  ownedProjects        Project[] @relation("ProjectOwner")

  @@index([organizationId])
  @@index([deletedAt])
  @@unique([microsoftTenantId, microsoftObjectId])
  @@map("users")
}

model MicrosoftSsoLoginChallenge {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @db.Uuid
  stateHash             String   @unique
  nonce                 String
  codeVerifierEncrypted String
  expiresAt             DateTime
  usedAt                DateTime?
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime @default(now())
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
  @@map("microsoft_sso_login_challenges")
}

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model MfaLoginChallenge {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
  ipAddress      String?
  userAgent      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([expiresAt])
  @@map("mfa_login_challenges")
}

model MfaSetupChallenge {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @db.Uuid
  userId          String    @db.Uuid
  tokenHash       String    @unique
  secretEncrypted String
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([expiresAt])
  @@map("mfa_setup_challenges")
}

model MfaTrustedDevice {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  tokenHash      String    @unique
  label          String?
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("mfa_trusted_devices")
}

model Group {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  name           String
  description    String?
  isSystem       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          UserGroup[]
  roles          GroupRole[]
  assignedTickets Ticket[] @relation("AssignedGroupTickets")
  routingRuleAssignments TicketRoutingRule[] @relation("RoutingRuleAssignGroup")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("groups")
}

model TicketTeam {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  name           String
  description    String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TicketTeamMember[]
  assignedTickets Ticket[] @relation("AssignedTeamTickets")
  routingRuleAssignments TicketRoutingRule[] @relation("RoutingRuleAssignTeam")
  assignedEventServiceRequests EventServiceRequest[] @relation("EventServiceAssignedTeam")

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
  @@map("ticket_teams")
}

model TicketTeamMember {
  id           String     @id @default(uuid()) @db.Uuid
  ticketTeamId String     @db.Uuid
  userId       String     @db.Uuid
  createdAt    DateTime   @default(now())
  ticketTeam   TicketTeam @relation(fields: [ticketTeamId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketTeamId, userId])
  @@index([userId])
  @@map("ticket_team_members")
}

model Role {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  name           String
  description    String?
  isSystem       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groups         GroupRole[]
  permissions    RolePermission[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       RolePermission[]

  @@map("permissions")
}

model UserGroup {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  groupId   String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("user_groups")
}

model GroupRole {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([groupId, roleId])
  @@map("group_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Client {
  id                  String       @id @default(uuid()) @db.Uuid
  organizationId      String       @db.Uuid
  name                String
  shortName           String?
  status              ClientStatus @default(ACTIVE)
  notes               String?
  slaProfile          String?
  billingProfile      String?
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  domains             ClientDomain[]
  contacts            Contact[]
  tickets             Ticket[]
  autoReplyTemplates  AutoReplyTemplate[]
  devices             Device[]
  ticketRoutingRules  TicketRoutingRule[]
  resolvedUnmappedDomains UnmappedEmailDomain[] @relation("ResolvedUnmappedDomainClient")
  eventServiceRequests EventServiceRequest[]
  projects             Project[]

  @@index([organizationId, status])
  @@index([deletedAt])
  @@map("clients")
}

model ClientDomain {
  id         String   @id @default(uuid()) @db.Uuid
  clientId   String   @db.Uuid
  domain     String   @unique
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([domain, isActive])
  @@map("client_domains")
}

model UnmappedEmailDomain {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  domain           String
  firstSenderEmail String?
  lastSenderEmail  String?
  messageCount     Int          @default(0)
  lastSeenAt       DateTime     @default(now())
  resolvedAt       DateTime?
  resolvedClientId String?      @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resolvedClient   Client?      @relation("ResolvedUnmappedDomainClient", fields: [resolvedClientId], references: [id], onDelete: SetNull)

  @@unique([organizationId, domain])
  @@index([organizationId, resolvedAt])
  @@map("unmapped_email_domains")
}

model Contact {
  id                    String   @id @default(uuid()) @db.Uuid
  clientId              String   @db.Uuid
  firstName             String
  lastName              String
  email                 String
  phone                 String?
  title                 String?
  isAuthorizedRequester Boolean  @default(true)
  isBillingContact      Boolean  @default(false)
  isTechnicalContact    Boolean  @default(false)
  notes                 String?
  deletedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ticketMessages        TicketMessage[] @relation("ContactAuthoredMessages")
  tickets               Ticket[]
  eventServiceRequests  EventServiceRequest[]

  @@unique([clientId, email])
  @@index([email])
  @@index([deletedAt])
  @@map("contacts")
}

model Mailbox {
