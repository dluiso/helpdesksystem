  @@index([clientId])
  @@index([contactId])
  @@index([senderDomain])
  @@index([mailboxId])
  @@index([status, priority])
  @@index([assignedUserId])
  @@index([firstReadAt])
  @@index([firstReadByUserId])
  @@index([assignedGroupId])
  @@index([assignedTeamId])
  @@index([appliedRoutingRuleId])
  @@index([mergedIntoTicketId])
  @@index([mergedByUserId])
  @@index([deletedAt])
  @@map("tickets")
}

